<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FENATS · Panel Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red:     #d40000;
      --red-dk:  #b80000;
      --red-lt:  rgba(212,0,0,.08);
      --ok:      #16a34a;
      --ok-lt:   rgba(22,163,74,.10);
      --warn:    #b45309;
      --warn-lt: rgba(180,83,9,.10);
      --text:    #111;
      --muted:   #666;
      --border:  #e4e4e4;
      --bg:      #f4f4f4;
      --white:   #ffffff;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: var(--bg);
      font-family: 'Barlow', sans-serif;
      color: var(--text);
      display: flex;
      flex-direction: column;
      background-image:
        radial-gradient(circle at 95% 5%, rgba(212,0,0,.06) 0%, transparent 45%),
        radial-gradient(circle at 5% 95%, rgba(212,0,0,.04) 0%, transparent 45%);
    }

    /* Banda roja superior */
    body::before {
      content: '';
      display: block;
      height: 5px;
      background: var(--red);
      flex-shrink: 0;
    }

    .page { flex: 1; padding: 24px 20px 32px; }
    .wrap { width: min(1020px, 100%); margin: 0 auto; }

    /* ── Navbar ── */
    .navbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
      margin-bottom: 28px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--border);
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .brand-logo {
      width: 44px;
      height: 44px;
      object-fit: contain;
      border-radius: 50%;
      background: white;
      padding: 3px;
      box-shadow: 0 2px 10px rgba(212,0,0,.18);
    }

    .brand-text { line-height: 1.15; }

    .brand-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 20px;
      font-weight: 900;
      color: var(--red);
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .brand-sub {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .nav { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 9px 14px;
      border-radius: 9px;
      border: 1.5px solid var(--border);
      background: var(--white);
      color: var(--text);
      text-decoration: none;
      font-family: 'Barlow', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      transition: border-color 0.15s, background 0.15s;
      white-space: nowrap;
    }

    .btn:hover { border-color: #bbb; background: #f9f9f9; }

    .btn-primary {
      background: var(--red);
      border-color: var(--red);
      color: white;
    }

    .btn-primary:hover { background: var(--red-dk); border-color: var(--red-dk); }

    .btn-ghost {
      background: transparent;
      border-color: var(--border);
      color: var(--muted);
    }

    .btn-ghost:hover { color: var(--text); border-color: #aaa; background: #f5f5f5; }

    /* ── Sección título ── */
    .section-head {
      margin-bottom: 16px;
    }

    .section-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 900;
      color: var(--text);
      letter-spacing: 0.3px;
      text-transform: uppercase;
    }

    .section-sub {
      margin-top: 3px;
      font-size: 13px;
      color: var(--muted);
      line-height: 1.4;
    }

    /* ── KPI Grid ── */
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      margin-bottom: 28px;
    }

    .kpi-card {
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 20px 22px;
      box-shadow: 0 1px 4px rgba(0,0,0,.05);
      position: relative;
      overflow: hidden;
    }

    /* Acento de color izquierdo */
    .kpi-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 4px;
      border-radius: 14px 0 0 14px;
    }

    .kpi-card.total::before  { background: #999; }
    .kpi-card.active::before { background: var(--ok); }
    .kpi-card.inactive::before { background: var(--warn); }

    .kpi-label {
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: 0.8px;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .kpi-num {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 44px;
      font-weight: 900;
      color: var(--text);
      line-height: 1;
      letter-spacing: -0.5px;
    }

    .kpi-card.active  .kpi-num { color: var(--ok); }
    .kpi-card.inactive .kpi-num { color: var(--warn); }

    .kpi-badge {
      margin-top: 12px;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 6px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.4px;
    }

    .kpi-card.total   .kpi-badge { background: #f0f0f0;       color: #555; }
    .kpi-card.active  .kpi-badge { background: var(--ok-lt);  color: var(--ok); }
    .kpi-card.inactive .kpi-badge { background: var(--warn-lt); color: var(--warn); }

    .kpi-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
    }

    .kpi-card.total    .kpi-dot { background: #999; }
    .kpi-card.active   .kpi-dot { background: var(--ok); }
    .kpi-card.inactive .kpi-dot { background: var(--warn); }

    /* ── Acciones rápidas ── */
    .actions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 12px;
    }

    .action-card {
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: 14px;
      padding: 18px 20px;
      text-decoration: none;
      color: var(--text);
      display: flex;
      align-items: flex-start;
      gap: 14px;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.12s;
      box-shadow: 0 1px 4px rgba(0,0,0,.04);
    }

    .action-card:hover {
      border-color: var(--red);
      box-shadow: 0 4px 16px rgba(212,0,0,.10);
      transform: translateY(-1px);
    }

    .action-icon {
      width: 38px; height: 38px;
      border-radius: 10px;
      background: var(--red-lt);
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .action-icon svg { width: 18px; height: 18px; fill: var(--red); }

    .action-body { flex: 1; }

    .action-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 15px;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.3px;
      color: var(--text);
    }

    .action-sub {
      margin-top: 3px;
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }

    @media (max-width: 720px) {
      .kpi-grid { grid-template-columns: 1fr; }
      .navbar { gap: 10px; }
    }
  </style>
</head>
<body>
  <% const isSuper = role === "SUPERADMIN"; %>
  <% const canManage = role === "ADMIN" || role === "SUPERADMIN"; %>

  <div class="page">
    <div class="wrap">

      <!-- Navbar -->
      <nav class="navbar">
        <div class="brand">
          <img class="brand-logo" src="/assets/screenshots/logo_fenats.jpeg" alt="Logo FENATS" />
          <div class="brand-text">
            <div class="brand-name">FENATS</div>
            <div class="brand-sub">Octava Región · Admin</div>
          </div>
        </div>

        <div class="nav">
          <% if (isSuper) { %>
            <a class="btn btn-primary" href="/admin/users">Crear Usuario</a>
          <% } %>
          <% if (canManage) { %>
            <a class="btn btn-primary" href="/admin/new">Nuevo socio</a>
            <a class="btn btn-primary" href="/admin/upload">Importar Excel</a>
          <% } %>
          <a class="btn" href="/admin/members">Ver socios</a>
          <a class="btn btn-ghost" href="/admin/logout">Salir</a>
        </div>
      </nav>

      <!-- KPIs -->
      <div class="section-head">
        <div class="section-title">Resumen de socios</div>
        <div class="section-sub">Estado actual del padrón registrado en el sistema.</div>
      </div>

      <div class="kpi-grid">
        <div class="kpi-card total">
          <div class="kpi-label">Total socios</div>
          <div class="kpi-num"><%= total %></div>
          <div class="kpi-badge">
            <span class="kpi-dot"></span>
            <span>Registros en base</span>
          </div>
        </div>

        <div class="kpi-card active">
          <div class="kpi-label">Vigentes</div>
          <div class="kpi-num"><%= active %></div>
          <div class="kpi-badge">
            <span class="kpi-dot"></span>
            <span>Estado activo</span>
          </div>
        </div>

        <div class="kpi-card inactive">
          <div class="kpi-label">No vigentes</div>
          <div class="kpi-num"><%= inactive %></div>
          <div class="kpi-badge">
            <span class="kpi-dot"></span>
            <span>Estado inactivo</span>
          </div>
        </div>
      </div>

      <!-- Acciones rápidas -->
      <% if (canManage) { %>
        <div class="section-head">
          <div class="section-title">Acciones rápidas</div>
          <div class="section-sub">Gestión del padrón de socios.</div>
        </div>

        <div class="actions-grid">
          <a class="action-card" href="/admin/members">
            <div class="action-icon">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M9 12a4 4 0 100-8 4 4 0 000 8zm-7 8a7 7 0 0114 0H2z"/>
              </svg>
            </div>
            <div class="action-body">
              <div class="action-title">Ver socios</div>
              <div class="action-sub">Buscar, activar/inactivar y gestionar tokens.</div>
            </div>
          </a>

          <a class="action-card" href="/admin/upload">
            <div class="action-icon">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1zm3.293-7.707a1 1 0 011.414 0L9 10.586V3a1 1 0 112 0v7.586l1.293-1.293a1 1 0 111.414 1.414l-3 3a1 1 0 01-1.414 0l-3-3a1 1 0 010-1.414z"/>
              </svg>
            </div>
            <div class="action-body">
              <div class="action-title">Importar Excel</div>
              <div class="action-sub">Carga masiva desde planilla FENATS.</div>
            </div>
          </a>

          <a class="action-card" href="/admin/new">
            <div class="action-icon">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M10 5a1 1 0 011 1v3h3a1 1 0 110 2h-3v3a1 1 0 11-2 0v-3H6a1 1 0 110-2h3V6a1 1 0 011-1z"/>
              </svg>
            </div>
            <div class="action-body">
              <div class="action-title">Nuevo socio</div>
              <div class="action-sub">Agregar un socio manualmente por RUT.</div>
            </div>
          </a>

          <% if (isSuper) { %>
          <a class="action-card" href="/admin/users">
            <div class="action-icon">
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zm5 2a2 2 0 11-4 0 2 2 0 014 0zm-4 7a4 4 0 00-8 0v1h8v-1zm6 0a2 2 0 00-2-2v3h2v-1z"/>
              </svg>
            </div>
            <div class="action-body">
              <div class="action-title">Usuarios admin</div>
              <div class="action-sub">Crear y gestionar accesos al panel.</div>
            </div>
          </a>

          <a class="action-card" href="/admin/posts">
  <div class="action-icon">
    <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
      <path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5zm3 1h10v2H5V6zm0 4h10v2H5v-2zm0 4h6v2H5v-2z"/>
    </svg>
  </div>
  <div class="action-body">
    <div class="action-title">Noticias</div>
    <div class="action-sub">Crear y gestionar noticias del sitio.</div>
  </div>
</a>

<a class="action-card" href="/admin/photos">
  <div class="action-icon">
    <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
      <path d="M4 3a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V5a2 2 0 00-2-2H4zm0 2h12v6.586l-2.293-2.293a1 1 0 00-1.414 0L9 12.586 7.707 11.293a1 1 0 00-1.414 0L4 13.586V5zm4 3a1 1 0 11-2 0 1 1 0 012 0z"/>
    </svg>
  </div>
  <div class="action-body">
    <div class="action-title">Galería</div>
    <div class="action-sub">Subir y eliminar fotos de la galería.</div>
  </div>
</a>
          <% } %>
        </div>
      <% } %>

    </div>
  </div>

  <%- include("../partials/footer") %>
</body>
</html>


