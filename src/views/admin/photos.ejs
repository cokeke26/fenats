<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FENATS · Galería y Convenios</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    :root{--red:#d40000;--red-dk:#b80000;--red-lt:rgba(212,0,0,.08);--red-br:rgba(212,0,0,.22);--ok:#16a34a;--ok-lt:rgba(22,163,74,.10);--ok-br:rgba(22,163,74,.28);--warn:#b45309;--warn-lt:rgba(180,83,9,.10);--warn-br:rgba(180,83,9,.28);--text:#111;--muted:#666;--border:#e4e4e4;--bg:#f4f4f4;--white:#ffffff;}
    *{box-sizing:border-box;margin:0;padding:0}
    body{min-height:100vh;background:var(--bg);font-family:'Barlow',sans-serif;color:var(--text);display:flex;flex-direction:column;background-image:radial-gradient(circle at 95% 5%,rgba(212,0,0,.06) 0%,transparent 45%);}
    body::before{content:'';display:block;height:5px;background:var(--red);flex-shrink:0;}
    .page{flex:1;padding:24px 20px 32px;}
    .wrap{width:min(1100px,100%);margin:0 auto;}
    .navbar{display:flex;align-items:center;justify-content:space-between;gap:12px;flex-wrap:wrap;margin-bottom:28px;padding-bottom:18px;border-bottom:1px solid var(--border);}
    .brand{display:flex;align-items:center;gap:12px;}
    .brand-logo{width:44px;height:44px;object-fit:contain;border-radius:50%;background:white;padding:3px;box-shadow:0 2px 10px rgba(212,0,0,.18);}
    .brand-name{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:900;color:var(--red);letter-spacing:1px;text-transform:uppercase;line-height:1.1;}
    .brand-sub{font-size:11px;font-weight:600;color:var(--muted);letter-spacing:.5px;text-transform:uppercase;}
    .nav{display:flex;gap:8px;flex-wrap:wrap;}
    .btn{display:inline-flex;align-items:center;justify-content:center;padding:9px 14px;border-radius:9px;border:1.5px solid var(--border);background:var(--white);color:var(--text);text-decoration:none;font-family:'Barlow',sans-serif;font-size:13px;font-weight:600;cursor:pointer;transition:border-color .15s,background .15s;white-space:nowrap;}
    .btn:hover{border-color:#bbb;background:#f9f9f9;}
    .btn-primary{background:var(--red);border-color:var(--red);color:white;}
    .btn-primary:hover{background:var(--red-dk);border-color:var(--red-dk);}
    .btn-ghost{background:transparent;color:var(--muted);}
    .btn-ghost:hover{color:var(--text);border-color:#aaa;}
    .btn-sm{padding:6px 10px;font-size:12px;border-radius:7px;display:inline-flex;align-items:center;justify-content:center;border:1.5px solid transparent;}
    .btn-sm-red{background:var(--red-lt);border-color:var(--red-br);color:var(--red);}
    .btn-sm-red:hover{background:rgba(212,0,0,.14);}
    .btn-sm-warn{background:var(--warn-lt);border-color:var(--warn-br);color:var(--warn);}
    .btn-sm-green{background:var(--ok-lt);border-color:var(--ok-br);color:var(--ok);}
    .tabs{display:flex;gap:4px;margin-bottom:20px;background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:4px;width:fit-content;}
    .tab{padding:8px 18px;border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;color:var(--muted);transition:background .12s,color .12s;user-select:none;}
    .tab.active{background:var(--red);color:white;}
    .tab-panel{display:none;}
    .tab-panel.active{display:block;}
    .layout-2{display:grid;grid-template-columns:300px 1fr;gap:16px;align-items:start;}
    .card{background:var(--white);border:1.5px solid var(--border);border-radius:16px;box-shadow:0 1px 4px rgba(0,0,0,.05);overflow:hidden;}
    .card-head-red{background:var(--red);padding:16px 20px 14px;}
    .card-head{padding:16px 20px 14px;border-bottom:1.5px solid var(--border);}
    .card-title-white{font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:900;color:white;text-transform:uppercase;letter-spacing:.3px;}
    .card-sub-white{margin-top:3px;font-size:11px;color:rgba(255,255,255,.75);}
    .card-title{font-family:'Barlow Condensed',sans-serif;font-size:17px;font-weight:900;color:var(--text);text-transform:uppercase;letter-spacing:.3px;}
    .card-sub{margin-top:3px;font-size:11px;color:var(--muted);}
    .card-body{padding:18px 20px;}
    .field{margin-bottom:13px;}
    .field-label{display:block;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.9px;text-transform:uppercase;margin-bottom:6px;}
    .field-input,.field-textarea{width:100%;padding:10px 12px;border:1.5px solid var(--border);border-radius:9px;font-family:'Barlow',sans-serif;font-size:13px;color:var(--text);background:#fafafa;outline:none;transition:border-color .15s;}
    .field-input:focus,.field-textarea:focus{border-color:var(--red);background:white;}
    .field-textarea{min-height:65px;resize:vertical;}
    .file-area{border:2px dashed var(--border);border-radius:9px;padding:14px;text-align:center;background:#fafafa;transition:border-color .15s,background .15s;}
    .file-trigger{display:flex;flex-direction:column;align-items:center;gap:5px;cursor:pointer;font-size:12px;color:var(--muted);padding:4px;}
    .file-trigger b{color:var(--red);}
    .file-trigger:hover{color:var(--text);}
    .file-name-display{margin-top:5px;font-size:12px;font-weight:600;color:var(--ok);display:none;}
    .alert{padding:10px 13px;border-radius:9px;font-size:13px;font-weight:600;margin-bottom:12px;}
    .alert-err{border:1.5px solid var(--red-br);background:var(--red-lt);color:var(--red);}
    .alert-ok{border:1.5px solid var(--ok-br);background:var(--ok-lt);color:var(--ok);}
    .photos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;}
    .photo-item{position:relative;border-radius:9px;overflow:hidden;border:1.5px solid var(--border);}
    .photo-img{width:100%;aspect-ratio:1;object-fit:cover;display:block;}
    .photo-overlay{position:absolute;inset:0;background:rgba(0,0,0,.5);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:6px;opacity:0;transition:opacity .15s;padding:8px;}
    .photo-item:hover .photo-overlay{opacity:1;}
    .photo-caption-text{font-size:11px;color:rgba(255,255,255,.85);text-align:center;line-height:1.3;}
    .conv-table{width:100%;border-collapse:collapse;}
    .conv-table th{text-align:left;padding:8px 12px;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:.6px;text-transform:uppercase;border-bottom:1.5px solid var(--border);background:#f8f8f8;}
    .conv-table td{padding:12px 14px;border-bottom:1px solid #f0f0f0;font-size:13px;vertical-align:middle;}
    .conv-table tr:last-child td{border-bottom:none;}
    .conv-table tr:hover td{background:#fafafa;}
    .conv-logo-thumb{width:40px;height:40px;object-fit:contain;border-radius:6px;border:1.5px solid var(--border);background:white;padding:3px;}
    .conv-logo-ph{width:40px;height:40px;border-radius:6px;border:1.5px solid var(--border);background:#f0f0f0;display:flex;align-items:center;justify-content:center;}
    .badge-active{display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:999px;font-size:11px;font-weight:700;}
    .badge-active.yes{background:var(--ok-lt);color:var(--ok);border:1.5px solid var(--ok-br);}
    .badge-active.no{background:var(--warn-lt);color:var(--warn);border:1.5px solid var(--warn-br);}
    .conv-actions{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
    .empty{text-align:center;padding:32px 20px;color:var(--muted);font-size:13px;}
    @media(max-width:800px){.layout-2{grid-template-columns:1fr;}}
  </style>
</head>
<body>
  <div class="page">
    <div class="wrap">
      <nav class="navbar">
        <div class="brand">
          <img class="brand-logo" src="/assets/screenshots/logo_fenats.jpeg" alt="Logo FENATS" />
          <div>
            <div class="brand-name">FENATS</div>
            <div class="brand-sub">Octava Región · Galería y Convenios</div>
          </div>
        </div>
        <div class="nav">
          <a class="btn" href="/admin">Panel</a>
          <a class="btn" href="/admin/posts">Noticias</a>
          <a class="btn btn-ghost" href="/admin/logout">Salir</a>
        </div>
      </nav>

      <% if (error) { %><div class="alert alert-err"><%= error %></div><% } %>
      <% if (message) { %><div class="alert alert-ok"><%= message %></div><% } %>

      <!-- Tabs — sin onclick inline, manejado por JS abajo -->
      <div class="tabs">
        <div class="tab active" data-tab="galeria">Galería de fotos</div>
        <div class="tab" data-tab="convenios">Convenios</div>
      </div>

      <!-- TAB: Galería -->
      <div id="tab-galeria" class="tab-panel active">
        <div class="layout-2">
          <div class="card">
            <div class="card-head-red">
              <div class="card-title-white">Subir foto</div>
              <div class="card-sub-white">Aparecerá en la galería de la página principal.</div>
            </div>
            <div class="card-body">
              <form method="post" action="/admin/photos/new" enctype="multipart/form-data">
                <div class="field">
                  <label class="field-label">Imagen</label>
                  <div class="file-area" id="photoArea">
                    <!-- ✅ label solo como trigger visual, input FUERA del label -->
                    <label class="file-trigger" for="photoInput">
                      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="2" stroke-linecap="round" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                      <span>Seleccionar o arrastrar</span>
                      <b>imagen aquí</b>
                    </label>
                    <!-- ✅ input fuera del label -->
                    <input id="photoInput" type="file" name="image" accept="image/*" style="display:none;" />
                    <div class="file-name-display" id="photoName"></div>
                  </div>
                </div>
                <div class="field">
                  <label class="field-label" for="caption">Descripción (opcional)</label>
                  <textarea class="field-textarea" id="caption" name="caption" placeholder="Ej: Reunión directiva enero 2026"></textarea>
                </div>
                <button class="btn btn-primary" type="submit" style="width:100%;padding:11px;">Subir foto</button>
              </form>
            </div>
          </div>

          <div class="card">
            <div class="card-head">
              <div class="card-title">Fotos subidas (<%= photos.length %>)</div>
              <div class="card-sub">Pasa el cursor sobre una foto para eliminarla.</div>
            </div>
            <div class="card-body">
              <% if (!photos || photos.length === 0) { %>
                <div class="empty">No hay fotos aún.</div>
              <% } else { %>
                <div class="photos-grid">
                  <% photos.forEach(function(ph) { %>
                    <div class="photo-item">
                      <img class="photo-img" src="<%= ph.imageUrl %>" alt="<%= ph.caption ?? 'Foto' %>" />
                      <div class="photo-overlay">
                        <% if (ph.title) { %><div class="photo-caption-text"><%= ph.title %></div><% } %>
                        <div style="display:flex;gap:6px;">
                          <a href="/admin/photos/<%= ph.id %>/edit" class="btn btn-sm">Editar</a>
                          <form method="post" action="/admin/photos/<%= ph.id %>/delete" onsubmit="return confirm('¿Eliminar esta foto?')">
                            <button class="btn btn-sm btn-sm-red" type="submit">Eliminar</button>
                          </form>
                        </div>
                      </div>
                    </div>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <!-- TAB: Convenios -->
      <div id="tab-convenios" class="tab-panel">
        <div class="layout-2">
          <div class="card">
            <div class="card-head-red">
              <div class="card-title-white">Agregar convenio</div>
              <div class="card-sub-white">El logo aparecerá en el carrusel de la página principal.</div>
            </div>
            <div class="card-body">
              <form method="post" action="/admin/convenios/new" enctype="multipart/form-data">
                <div class="field">
                  <label class="field-label" for="convName">Nombre del convenio</label>
                  <input class="field-input" id="convName" name="name" type="text" placeholder="Ej: Farmacia Cruz Verde" required />
                </div>
                <div class="field">
                  <label class="field-label" for="convAddress">Dirección</label>
                  <input class="field-input" id="convAddress" name="address" type="text" placeholder="Ej: Av. Los Héroes 123" required />
                </div>
                <div class="field">
                  <label class="field-label" for="convPhone">Teléfono</label>
                  <input class="field-input" id="convPhone" name="phone" type="tel" placeholder="Ej: +56 9 1234 5678" required />
                </div>
                <div class="field">
                  <label class="field-label">Logo (opcional)</label>
                  <div class="file-area" id="logoArea">
                    <!-- ✅ label solo como trigger visual, input FUERA del label -->
                    <label class="file-trigger" for="logoInput">
                      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#bbb" stroke-width="2" stroke-linecap="round" xmlns="http://www.w3.org/2000/svg"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
                      <span>Seleccionar logo</span>
                      <b>PNG o SVG recomendado</b>
                    </label>
                    <!-- ✅ input fuera del label -->
                    <input id="logoInput" type="file" name="logo" accept="image/*" style="display:none;" />
                    <div class="file-name-display" id="logoName"></div>
                  </div>
                  <div style="margin-top:6px;font-size:11px;color:var(--muted);">Sin logo se mostrará el nombre del convenio en el carrusel.</div>
                </div>
                <button class="btn btn-primary" type="submit" style="width:100%;padding:11px;">Agregar convenio</button>
              </form>
            </div>
          </div>

          <div class="card">
            <div class="card-head">
              <div class="card-title">Convenios registrados (<%= convenios ? convenios.length : 0 %>)</div>
              <div class="card-sub">Activa o desactiva convenios sin borrarlos.</div>
            </div>
            <div class="card-body" style="padding:0;">
              <% if (!convenios || convenios.length === 0) { %>
                <div class="empty">No hay convenios aún.</div>
              <% } else { %>
                <table class="conv-table">
                  <thead>
                    <tr>
                      <th style="width:56px;">Logo</th>
                      <th>Nombre</th>
                      <th>Dirección</th>
                      <th>Teléfono</th>
                      <th>Estado</th>
                      <th style="text-align:right;">Acciones</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% convenios.forEach(function(c) { %>
                      <tr>
                        <td>
                          <% if (c.logoUrl) { %>
                            <img class="conv-logo-thumb" src="<%= c.logoUrl %>" alt="<%= c.name %>" />
                          <% } else { %>
                            <div class="conv-logo-ph">
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="#ccc"><path d="M4 5a1 1 0 011-1h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V5z"/></svg>
                            </div>
                          <% } %>
                        </td>
                        <td style="font-weight:600;"><%= c.name %></td>
                        <td><%= c.address %></td>
                        <td><%= c.phone %></td>
                        <td>
                          <span class="badge-active <%= c.active ? 'yes' : 'no' %>">
                            <%= c.active ? 'Activo' : 'Inactivo' %>
                          </span>
                        </td>
                        <td>
                          <div class="conv-actions" style="justify-content:flex-end;">
                            <form method="post" action="/admin/convenios/<%= c.id %>/toggle">
                              <button class="btn btn-sm <%= c.active ? 'btn-sm-warn' : 'btn-sm-green' %>" type="submit">
                                <%= c.active ? 'Desactivar' : 'Activar' %>
                              </button>
                            </form>
                            <a href="/admin/convenios/<%= c.id %>/edit" class="btn btn-sm">Editar</a>
                            <form method="post" action="/admin/convenios/<%= c.id %>/delete" onsubmit="return confirm('¿Eliminar este convenio?')">
                              <button class="btn btn-sm btn-sm-red" type="submit">Eliminar</button>
                            </form>
                          </div>
                        </td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
              <% } %>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <script>
    // ✅ Tabs con event listeners — no onclick inline
    function showTab(name) {
      document.querySelectorAll(".tab-panel").forEach(p => p.classList.remove("active"));
      document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
      document.getElementById("tab-" + name).classList.add("active");
      document.querySelector(`.tab[data-tab="${name}"]`).classList.add("active");
    }

    document.querySelectorAll(".tab").forEach(tab => {
      tab.addEventListener("click", () => showTab(tab.dataset.tab));
    });

    const initialTab = "<%= typeof activeTab !== 'undefined' ? activeTab : '' %>";
    if (initialTab === "convenios" || window.location.hash === "#convenios") {
    showTab("convenios");
    }

    // ✅ Preview de archivos — input fuera del label, evento directo
    function filePreview(inputId, nameId, areaId) {
      const input  = document.getElementById(inputId);
      const nameEl = document.getElementById(nameId);
      const area   = document.getElementById(areaId);
      if (!input) return;
      input.addEventListener("change", () => {
        if (input.files[0]) {
          nameEl.textContent    = "✓ " + input.files[0].name;
          nameEl.style.display  = "block";
          area.style.borderColor = "#16a34a";
          area.style.background  = "rgba(22,163,74,.06)";
        }
      });
    }

    filePreview("photoInput", "photoName", "photoArea");
    filePreview("logoInput",  "logoName",  "logoArea");
  </script>

  <%- include("../partials/footer") %>
</body>
</html>