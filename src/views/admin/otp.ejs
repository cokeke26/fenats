<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FENATS · Verificación</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red:    #d40000;
      --red-dk: #b80000;
      --red-lt: rgba(212,0,0,.08);
      --ok:     #16a34a;
      --ok-lt:  rgba(22,163,74,.10);
      --text:   #111;
      --muted:  #666;
      --border: #e0e0e0;
      --bg:     #f4f4f4;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: var(--bg);
      font-family: 'Barlow', sans-serif;
      color: var(--text);
      display: flex;
      flex-direction: column;
      background-image:
        radial-gradient(circle at 90% 10%, rgba(212,0,0,.06) 0%, transparent 45%),
        radial-gradient(circle at 10% 90%, rgba(212,0,0,.04) 0%, transparent 45%);
    }

    body::before {
      content: '';
      display: block;
      height: 5px;
      background: var(--red);
      flex-shrink: 0;
    }

    .page {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    /* Brand */
    .brand {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 26px;
    }

    .brand-logo {
      width: 56px; height: 56px;
      object-fit: contain;
      border-radius: 50%;
      background: white;
      padding: 3px;
      box-shadow: 0 4px 16px rgba(212,0,0,.20);
    }

    .brand-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 24px;
      font-weight: 900;
      color: var(--red);
      letter-spacing: 1px;
      text-transform: uppercase;
      line-height: 1.1;
    }

    .brand-sub {
      font-size: 11px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    /* Card */
    .card {
      width: min(420px, 100%);
      background: white;
      border-radius: 18px;
      box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 10px 40px rgba(0,0,0,.10);
      overflow: hidden;
    }

    .card-head {
      background: var(--red);
      padding: 20px 26px 18px;
    }

    .card-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 21px;
      font-weight: 900;
      color: white;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .card-sub {
      margin-top: 4px;
      font-size: 12px;
      color: rgba(255,255,255,.78);
      line-height: 1.4;
    }

    .card-body { padding: 26px 26px 22px; }

    /* Input OTP */
    .otp-input {
      width: 100%;
      padding: 16px 14px;
      border: 2px solid var(--border);
      border-radius: 12px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 32px;
      font-weight: 700;
      letter-spacing: 10px;
      text-align: center;
      color: var(--text);
      background: #fafafa;
      outline: none;
      transition: border-color 0.15s, background 0.15s;
    }

    .otp-input:focus { border-color: var(--red); background: white; }
    .otp-input::placeholder { color: #ccc; letter-spacing: 6px; font-size: 24px; }

    /* Estado del código */
    .code-status {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      margin-top: 10px;
      padding: 6px 12px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 700;
      background: #f0f0f0;
      color: var(--muted);
      transition: background 0.2s, color 0.2s;
    }

    .code-status.complete {
      background: var(--ok-lt);
      color: var(--ok);
    }

    .status-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #ccc;
      transition: background 0.2s;
    }

    .code-status.complete .status-dot { background: var(--ok); }

    /* Botón principal */
    .btn-submit {
      width: 100%;
      padding: 13px;
      margin-top: 14px;
      background: var(--red);
      color: white;
      border: none;
      border-radius: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
    }

    .btn-submit:hover  { background: var(--red-dk); }
    .btn-submit:active { transform: scale(0.99); }

    /* Alertas */
    .alert {
      margin-top: 12px;
      padding: 10px 14px;
      border-radius: 10px;
      font-size: 13px;
      line-height: 1.45;
    }

    .alert-error {
      border: 1.5px solid rgba(212,0,0,.25);
      background: var(--red-lt);
      color: #a00;
    }

    .alert-ok {
      border: 1.5px solid rgba(22,163,74,.25);
      background: var(--ok-lt);
      color: var(--ok);
    }

    /* Fila de acciones secundarias */
    .row {
      display: flex;
      gap: 10px;
      margin-top: 12px;
    }

    .btn-secondary {
      flex: 1;
      padding: 10px 12px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      background: white;
      color: var(--text);
      font-family: 'Barlow', sans-serif;
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      text-align: center;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      transition: border-color 0.15s, background 0.15s;
    }

    .btn-secondary:hover { border-color: #bbb; background: #f9f9f9; }

    .btn-secondary:disabled {
      opacity: .5;
      cursor: not-allowed;
    }

    /* Pie */
    .card-foot {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid #f0f0f0;
      font-size: 12px;
      color: #999;
      line-height: 1.5;
      text-align: center;
    }

    .page-foot {
      margin-top: 22px;
      font-size: 11px;
      color: #bbb;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="page">

    <div class="brand">
      <img class="brand-logo" src="/assets/screenshots/logo_fenats.jpeg" alt="Logo FENATS" />
      <div>
        <div class="brand-name">FENATS</div>
        <div class="brand-sub">Octava Región · Verificación</div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <div class="card-title">Ingresa el código</div>
        <div class="card-sub">Te enviamos un código de 6 dígitos a tu correo. Tiene una duración de 10 minutos.</div>
      </div>

      <div class="card-body">
        <form method="post" action="/admin/otp" autocomplete="off">
          <input
            id="code"
            class="otp-input"
            name="code"
            type="text"
            inputmode="numeric"
            pattern="\d{6}"
            maxlength="6"
            placeholder="● ● ● ● ● ●"
            required
          />

          <div class="code-status" id="codeStatus">
            <span class="status-dot" id="statusDot"></span>
            <span id="statusText">Ingresa los 6 dígitos</span>
          </div>

          <button class="btn-submit" type="submit">Verificar</button>

          <% if (error) { %>
            <div class="alert alert-error"><b>Error:</b> <%= error %></div>
          <% } %>

          <% if (message) { %>
            <div class="alert alert-ok"><b>OK:</b> <%= message %></div>
          <% } %>
        </form>

        <div class="row">
          <form method="post" action="/admin/otp/resend" style="flex:1">
            <button class="btn-secondary" id="resendBtn" type="submit" style="width:100%">
              Reenviar código
            </button>
          </form>
          <a class="btn-secondary" href="/admin/login">Volver</a>
        </div>

        <div class="card-foot">
          Si no te llega el correo, revisa <b>Spam</b> o <b>No deseados</b>.<br>
          Si el problema persiste, solicita a FENATS que valide tu correo.
        </div>
      </div>
    </div>

    <div class="page-foot">Sistema desarrollado por Hidracode Solutions</div>
  </div>

  <script>
    const codeInput  = document.getElementById("code");
    const codeStatus = document.getElementById("codeStatus");
    const statusText = document.getElementById("statusText");
    const resendBtn  = document.getElementById("resendBtn");

    // Solo dígitos, actualiza estado visual
    codeInput.addEventListener("input", () => {
      codeInput.value = codeInput.value.replace(/[^\d]/g, "").slice(0, 6);
      const complete  = codeInput.value.length === 6;
      codeStatus.classList.toggle("complete", complete);
      statusText.textContent = complete ? "Código completo ✓" : "Ingresa los 6 dígitos";
    });

    if (codeInput) codeInput.focus();

    // Cooldown visual de 45s para reenviar
    let seconds = 45;
    (function tick() {
      if (!resendBtn) return;
      if (seconds > 0) {
        resendBtn.disabled = true;
        resendBtn.textContent = `Reenviar en ${seconds}s`;
        seconds--;
        setTimeout(tick, 1000);
      } else {
        resendBtn.disabled = false;
        resendBtn.textContent = "Reenviar código";
      }
    })();
  </script>

  <%- include("../partials/footer") %>
</body>
</html>

