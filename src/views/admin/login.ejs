<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FENATS · Ingreso Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red:     #d40000;
      --red-dk:  #b80000;
      --red-lt:  rgba(212,0,0,.08);
      --text:    #111;
      --muted:   #666;
      --border:  #e0e0e0;
      --bg:      #f4f4f4;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: var(--bg);
      font-family: 'Barlow', sans-serif;
      color: var(--text);
      display: flex;
      flex-direction: column;

      /* Marca de agua sutil */
      background-image:
        radial-gradient(circle at 90% 10%, rgba(212,0,0,.07) 0%, transparent 50%),
        radial-gradient(circle at 10% 90%, rgba(212,0,0,.05) 0%, transparent 50%);
    }

    /* Banda roja superior */
    body::before {
      content: '';
      display: block;
      height: 5px;
      background: var(--red);
      flex-shrink: 0;
    }

    .page {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    /* Logo + nombre institución */
    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }

    .brand-logo {
      width: 64px;
      height: 64px;
      object-fit: contain;
      border-radius: 50%;
      box-shadow: 0 4px 18px rgba(212,0,0,.22);
      background: white;
      padding: 4px;
    }

    .brand-text {
      line-height: 1.15;
    }

    .brand-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 28px;
      font-weight: 900;
      color: var(--red);
      letter-spacing: 1.5px;
      text-transform: uppercase;
    }

    .brand-sub {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.6px;
      text-transform: uppercase;
    }

    /* Card principal */
    .card {
      width: min(420px, 100%);
      background: white;
      border-radius: 18px;
      box-shadow:
        0 1px 3px rgba(0,0,0,.06),
        0 10px 40px rgba(0,0,0,.10);
      overflow: hidden;
    }

    .card-head {
      background: var(--red);
      padding: 22px 26px 18px;
    }

    .card-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 21px;
      font-weight: 900;
      color: white;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .card-sub {
      margin-top: 4px;
      font-size: 12px;
      color: rgba(255,255,255,.78);
      line-height: 1.4;
    }

    .card-body {
      padding: 26px 26px 22px;
    }

    /* Campos */
    .field {
      margin-bottom: 16px;
    }

    .field label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: 0.9px;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .field input {
      width: 100%;
      padding: 12px 14px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: 'Barlow', sans-serif;
      font-size: 15px;
      color: var(--text);
      background: #fafafa;
      outline: none;
      transition: border-color 0.15s, background 0.15s;
    }

    .field input:focus {
      border-color: var(--red);
      background: white;
    }

    /* Botón */
    .btn-submit {
      width: 100%;
      padding: 13px;
      margin-top: 4px;
      background: var(--red);
      color: white;
      border: none;
      border-radius: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 18px;
      font-weight: 900;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
    }

    .btn-submit:hover  { background: var(--red-dk); }
    .btn-submit:active { transform: scale(0.99); }

    /* Error */
    .alert {
      margin-top: 14px;
      padding: 11px 14px;
      border: 1.5px solid rgba(212,0,0,.30);
      background: var(--red-lt);
      border-radius: 10px;
      font-size: 13px;
      color: #a00;
      line-height: 1.45;
    }

    /* Pie de card */
    .card-foot {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid #f0f0f0;
      font-size: 12px;
      color: #999;
      line-height: 1.5;
      text-align: center;
    }

    /* Pie de página */
    .page-foot {
      margin-top: 24px;
      font-size: 11px;
      color: #bbb;
      letter-spacing: 0.2px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="page">

    <div class="brand">
      <img class="brand-logo" src="/assets/screenshots/logo_fenats.jpeg" alt="Logo FENATS" />
      <div class="brand-text">
        <div class="brand-name">FENATS</div>
        <div class="brand-sub">Octava Región · Panel Admin</div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <div class="card-title">Ingreso de administración</div>
        <div class="card-sub">Acceso restringido · gestión de socios y planillas</div>
      </div>

      <div class="card-body">
        <form method="post" action="/admin/login" autocomplete="on">

          <div class="field">
            <label for="username">Usuario</label>
            <input
              id="username"
              type="text"
              name="username"
              placeholder="Ej: 12345678"
              value="<%= typeof username !== 'undefined' ? username : '' %>"
              autocomplete="username"
              required
            />
          </div>

          <div class="field">
            <label for="password">Contraseña</label>
            <input
              id="password"
              type="password"
              name="password"
              placeholder="••••••••"
              autocomplete="current-password"
              required
            />
          </div>

          <button class="btn-submit" type="submit">Ingresar</button>

          <% if (error) { %>
            <div class="alert"><b>Error:</b> <%= error %></div>
          <% } %>

        </form>

        <div class="card-foot">
          Si olvidaste tu acceso, solicita a tu jefatura que te restablezca la contraseña.
        </div>
      </div>
    </div>

  
  </div>

  <script>
    const u = document.getElementById('username');
    if (u && !u.value) u.focus();
  </script>

  <%- include("../partials/footer") %>
</body>
</html>



