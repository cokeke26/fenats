<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FENATS · Credencial Socio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet" />
  <style>
    :root {
      --red:    #d40000;
      --red-dk: #b80000;
      --red-lt: rgba(212,0,0,.08);
      --text:   #111;
      --muted:  #666;
      --border: #e0e0e0;
      --bg:     #f4f4f4;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      min-height: 100vh;
      background: var(--bg);
      font-family: 'Barlow', sans-serif;
      color: var(--text);
      display: flex;
      flex-direction: column;
      background-image:
        radial-gradient(circle at 90% 10%, rgba(212,0,0,.06) 0%, transparent 45%),
        radial-gradient(circle at 10% 90%, rgba(212,0,0,.04) 0%, transparent 45%);
    }

    body::before {
      content: '';
      display: block;
      height: 5px;
      background: var(--red);
      flex-shrink: 0;
    }

    .page {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 32px 16px;
    }

    /* Brand */
    .brand {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }

    .brand-logo {
      width: 72px; height: 72px;
      object-fit: contain;
      border-radius: 50%;
      background: white;
      padding: 4px;
      box-shadow: 0 4px 20px rgba(212,0,0,.22);
    }

    .brand-text { line-height: 1.15; }

    .brand-name {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 32px;
      font-weight: 900;
      color: var(--red);
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .brand-sub {
      font-size: 12px;
      font-weight: 600;
      color: var(--muted);
      letter-spacing: 0.6px;
      text-transform: uppercase;
    }

    /* Card */
    .card {
      width: min(420px, 100%);
      background: white;
      border-radius: 18px;
      box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 10px 40px rgba(0,0,0,.10);
      overflow: hidden;
    }

    .card-head {
      background: var(--red);
      padding: 22px 26px 18px;
    }

    .card-title {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 900;
      color: white;
      letter-spacing: 0.5px;
      text-transform: uppercase;
    }

    .card-sub {
      margin-top: 5px;
      font-size: 13px;
      color: rgba(255,255,255,.80);
      line-height: 1.45;
    }

    .card-body { padding: 26px; }

    /* Campo RUT */
    .field-label {
      display: block;
      font-size: 11px;
      font-weight: 700;
      color: var(--muted);
      letter-spacing: 0.9px;
      text-transform: uppercase;
      margin-bottom: 7px;
    }

    .field-input {
      width: 100%;
      padding: 13px 16px;
      border: 1.5px solid var(--border);
      border-radius: 10px;
      font-family: 'Barlow', sans-serif;
      font-size: 17px;
      color: var(--text);
      background: #fafafa;
      outline: none;
      transition: border-color 0.15s, background 0.15s;
      letter-spacing: 0.5px;
    }

    .field-input:focus { border-color: var(--red); background: white; }
    .field-input::placeholder { color: #bbb; font-size: 15px; }

    /* Botón */
    .btn-submit {
      width: 100%;
      padding: 14px;
      margin-top: 14px;
      background: var(--red);
      color: white;
      border: none;
      border-radius: 10px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 19px;
      font-weight: 900;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
    }

    .btn-submit:hover  { background: var(--red-dk); }
    .btn-submit:active { transform: scale(0.99); }

    /* Error */
    .alert {
      margin-top: 14px;
      padding: 11px 14px;
      border: 1.5px solid rgba(212,0,0,.28);
      background: var(--red-lt);
      border-radius: 10px;
      font-size: 13px;
      color: #a00;
      line-height: 1.45;
    }

    /* Tip */
    .card-foot {
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid #f0f0f0;
      font-size: 12px;
      color: #999;
      line-height: 1.55;
      text-align: center;
    }

    /* Pie de página */
    .page-foot {
      margin-top: 24px;
      font-size: 11px;
      color: #bbb;
      letter-spacing: 0.2px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="page">

    <div class="brand">
      <img class="brand-logo" src="/assets/screenshots/logo_fenats.jpeg" alt="Logo FENATS" />
      <div class="brand-text">
        <div class="brand-name">FENATS</div>
        <div class="brand-sub">Octava Región · Credencial Digital</div>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <div class="card-title">Ingresar a tu credencial</div>
        <div class="card-sub">Ingresa tu <b>RUT con DV</b> para abrir tu credencial con código QR.</div>
      </div>

      <div class="card-body">
        <form method="post" action="/login-member" autocomplete="on">

          <label class="field-label" for="rut">Tu RUT</label>
          <input
            class="field-input"
            id="rut"
            type="text"
            name="rut"
            placeholder="Ej: 9.313.137-1"
            value="<%= typeof rut !== 'undefined' ? rut : '' %>"
            autocomplete="username"
            required
          />

          <button class="btn-submit" type="submit">Ver credencial</button>

          <% if (error) { %>
            <div class="alert"><b>Error:</b> <%= error %></div>
          <% } %>

        </form>

        <div class="card-foot">
          Puedes escribir el RUT con o sin puntos.<br>
          Debe incluir el <b>DV</b> — ej: <b>12.345.678-9</b>
        </div>
      </div>
    </div>

    <div class="page-foot">Sistema desarrollado por Hidracode Solutions</div>
  </div>

  <script>
    const r = document.getElementById("rut");
    if (r && !r.value) r.focus();
  </script>

  <%- include("../partials/footer") %>
</body>
</html>

